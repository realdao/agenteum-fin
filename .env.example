AGENTEUM_HOST=127.0.0.1
AGENTEUM_PORT=8766
AGENTEUM_ALLOW_REMOTE=false
AGENTEUM_FIN_REQUEST_TIMEOUT=15.0
AGENTEUM_FIN_RETRY_ATTEMPTS=1
AGENTEUM_FIN_RETRY_BACKOFF_SECONDS=0.5
AGENTEUM_FIN_A_KLINE_PROVIDER=tencent
AGENTEUM_FIN_HK_KLINE_PROVIDER=tencent
AGENTEUM_FIN_PROFILE_PROVIDER=tencent
AGENTEUM_FIN_FINANCIAL_STATEMENTS_PROVIDER=sina
AGENTEUM_FIN_F10_PROVIDER=eastmoney
AGENTEUM_FIN_ANNOUNCEMENTS_PROVIDER=cninfo
# Iwencai (同花顺问财) flexible query layer. Set to "none" to disable the
# iwencai_query / iwencai_search tools.
AGENTEUM_FIN_IWENCAI_PROVIDER=iwencai
# API key from https://www.iwencai.com/skillhub (Skill -> 安装方式-Agent用户).
# Falls back to the IWENCAI_API_KEY environment variable when unset.
AGENTEUM_FIN_IWENCAI_API_KEY=
